{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://me-war-intel-brief/schemas/brief-frontmatter.json",
  "title": "ME War Intel Brief Frontmatter",
  "description": "YAML frontmatter schema for daily brief MDX files (v1.2).",
  "type": "object",
  "required": [
    "day",
    "date",
    "title",
    "escalation_direction",
    "escalation_risk_7d",
    "spillover_risk",
    "ceasefire_probability_30d",
    "key_developments",
    "sources",
    "casualties_snapshot",
    "clocks"
  ],
  "additionalProperties": false,
  "properties": {
    "report_type": {
      "type": "string"
    },
    "day": {
      "type": "integer",
      "minimum": 1,
      "maximum": 999,
      "description": "Day count from 2026-02-28 (Day 1)."
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "escalation_direction": {
      "enum": ["escalating", "mixed", "de-escalating"]
    },
    "escalation_risk_7d": {
      "enum": ["critical", "extreme", "conditional", "low"]
    },
    "spillover_risk": {
      "enum": ["critical", "conditional", "contained"]
    },
    "ceasefire_probability_30d": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "quiet_day": { "type": "boolean" },
    "gap_acknowledged": { "type": "boolean" },
    "casualty_revision": { "type": "boolean" },
    "key_developments": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 5 }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "url", "accessed_at"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "url": { "type": "string" },
          "accessed_at": { "type": "string" }
        }
      }
    },
    "casualties_snapshot": {
      "type": "object",
      "required": ["us", "israel", "iran", "other"],
      "additionalProperties": false,
      "properties": {
        "us": { "$ref": "#/definitions/actorCasualty" },
        "israel": { "$ref": "#/definitions/actorCasualty" },
        "iran": { "$ref": "#/definitions/actorCasualty" },
        "other": { "$ref": "#/definitions/actorCasualty" }
      }
    },
    "clocks": {
      "type": "object",
      "required": [
        "negotiation_capacity",
        "active_deadline",
        "interceptor_reconstitution",
        "energy_infrastructure",
        "humanitarian_escalation",
        "coalition_cohesion"
      ],
      "additionalProperties": false,
      "properties": {
        "negotiation_capacity": { "$ref": "#/definitions/clock" },
        "active_deadline": { "$ref": "#/definitions/clock" },
        "interceptor_reconstitution": { "$ref": "#/definitions/clock" },
        "energy_infrastructure": { "$ref": "#/definitions/clock" },
        "humanitarian_escalation": { "$ref": "#/definitions/clock" },
        "coalition_cohesion": { "$ref": "#/definitions/clock" }
      }
    }
  },
  "definitions": {
    "actorCasualty": {
      "type": "object",
      "required": ["killed", "wounded", "delta_24_48h"],
      "additionalProperties": false,
      "properties": {
        "killed": { "type": "integer", "minimum": 0 },
        "wounded": { "type": "integer", "minimum": 0 },
        "delta_24_48h": { "type": "string" }
      }
    },
    "clock": {
      "type": "object",
      "required": ["state", "trajectory"],
      "additionalProperties": false,
      "properties": {
        "state": {
          "enum": [
            "active",
            "advancing",
            "approaching",
            "critical",
            "deteriorating",
            "elevated",
            "expiring",
            "extension_likely",
            "holding",
            "improving",
            "paused",
            "strained",
            "strong",
            "unclear"
          ]
        },
        "trajectory": {
          "enum": ["improving", "worsening", "unchanged", "deadline_removed"]
        }
      }
    }
  }
}
